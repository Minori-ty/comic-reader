{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "comic-dev",
  "version": "0.1.0",
  "identifier": "com.tauri-app.comic-dev",
  "build": {
    "beforeDevCommand": "pnpm build:web && pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "comic-dev",
        "width": 1000,
        "height": 700
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
