{
    "name": "comic-dev",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build:web": "cd web && pnpm build",
        "build": "pnpm build:web && tsc && vite build",
        "preview": "vite preview",
        "tauri": "tauri",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "format": "oxfmt --write src web ./CLAUDE.md ./package.json ./.oxfmtrc.json ./.oxlintrc.json",
        "format:check": "oxfmt --check",
        "lint:all": "pnpm lint && cd web && pnpm lint",
        "format:all": "pnpm format && cd web && pnpm format"
    },
    "dependencies": {
        "@tanstack/react-query": "^5.101.0",
        "@tanstack/react-virtual": "^3.14.3",
        "@tauri-apps/api": "^2",
        "@tauri-apps/plugin-dialog": "^2.7.1",
        "@tauri-apps/plugin-fs": "^2.5.1",
        "@tauri-apps/plugin-opener": "^2",
        "i18next": "^26.3.1",
        "qrcode": "^1.5",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "react-i18next": "^17.0.8",
        "react-router-dom": "^7.18.0",
        "zustand": "^5.0.14"
    },
    "devDependencies": {
        "@tauri-apps/cli": "^2",
        "@types/qrcode": "^1.5.6",
        "@types/react": "^19.1.8",
        "@types/react-dom": "^19.1.6",
        "@vitejs/plugin-react": "^4.6.0",
        "oxfmt": "^0.56.0",
        "oxlint": "^1.71.0",
        "typescript": "~5.8.3",
        "vite": "^7.0.4"
    }
